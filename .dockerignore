# Ignore all files by default
**

# Allow source code and project configuration
!src/**
!app/**
!pyproject.toml
!uv.lock
!README.md
!docs/**

# Allow specific configuration files
!*.py
!*.toml
!*.lock
!*.md

# Ignore Python artifacts
**/__pycache__/
**/*.py[cod]
**/*.so

# Ignore environments and caches
.venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Ignore local configs and secrets
.env
.env.*
.git/
.gitignore
.dockerignore
.vscode/
.idea/

# Ignore AI-specific files (optionally exclude from build)
GEMINI.md
CLAUDE.md
.codex
